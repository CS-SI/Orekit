@startuml

  skinparam svek                  true
  skinparam ClassBackgroundColor  #F3EFEB/CCC9C5
  skinparam ClassArrowColor       #691616
  skinparam ClassBorderColor      #691616
  skinparam NoteBackgroundColor   #F3EFEB
  skinparam NoteBorderColor       #691616
    skinparam ClassFontSize         11
  skinparam PackageFontSize       12
  skinparam linetype              ortho

  package org.orekit.propagation #ECEBD8 {

    abstract AbstractGradientConverter {
      +FieldSpacecraftState<Gradient> buildBasicGradientSpacecraftState()
      +FieldSpacecraftState<Gradient> getState(parametricModel)
    }
    note right
    gradient here is **always** in Cartesian parameters
    end note

    package semianalytical #DDEBD8 {
      package dsst #CBDBC8 {
        class DSSTGradientConverter
      }
    }

    package numerical #DDEBD8 {
      class NumericalGradientConverter
    }

    package analytical #DDEBD8 {

      abstract AbstractAnalyticalGradientConverter {
        #FieldAbstractAnalyticalPropagator<Gradient> getPropagator()
      }

      class BrouwerLyddaneGradientConverter
      class EcksteinHechlerGradientConverter
      class KeplerianGradientConverter

      package tle #CBDBC8 {
        class TLEGradientConverter
      }

      package gnss #CBDBC8 {
        class GnssGradientConverter
      }

    }

    AbstractGradientConverter           <|-- NumericalGradientConverter
    AbstractGradientConverter           <|-- DSSTGradientConverter
    AbstractGradientConverter           <|-- AbstractAnalyticalGradientConverter
    AbstractAnalyticalGradientConverter <|-- BrouwerLyddaneGradientConverter
    AbstractAnalyticalGradientConverter <|-- EcksteinHechlerGradientConverter
    AbstractAnalyticalGradientConverter <|-- KeplerianGradientConverter
    AbstractAnalyticalGradientConverter <|-- TLEGradientConverter
    AbstractAnalyticalGradientConverter <|-- GnssGradientConverter

  }

@enduml
