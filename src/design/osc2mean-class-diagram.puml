@startuml

  skinparam svek                  true
  skinparam ClassBackgroundColor  #F3EFEB/CCC9C5
  skinparam ClassArrowColor       #691616
  skinparam ClassBorderColor      #691616
  skinparam NoteBackgroundColor   #F3EFEB
  skinparam NoteBorderColor       #691616
  skinparam NoteFontColor         #691616
  skinparam ClassFontSize         11
  skinparam PackageFontSize       12
  skinparam Padding               2
  skinparam linetype              ortho
  hide empty members

  package org.orekit #ECEBD8 {

    package "propagation.conversion.osc2mean" #DDEBD8 {

      together {
        class FixedPointConverter {
          +int getIterationsNb()
        }

        class LeastSquaresConverter {
          +void setOptimizer(LeastSquaresOptimizer)
          +double getRMS()
          +int getIterationsNb()
        }
      }

      interface OsculatingToMeanConverter {
        +void setMeanTheory(MeanTheory)
        +MeanTheory getMeanTheory()
        +Orbit convertToMean(Orbit)
      }

      interface MeanTheory {
        +String getTheoryName()
        +Orbit preprocessing(Orbit)
        +Orbit initialize(Orbit)
        +Orbit meanToOsculating(Orbit)
        +Orbit postprocessing(Orbit, Orbit)
      }

      together {
        class BrouwerLyddaneTheory
        class EcksteinHechlerTheory
        class DSSTTheory
        class TLETheory
      }

    }

    package propagation #DDEBD8 {

      package analytical #CBDBC8 {
        together {
          class BrouwerLyddanePropagator
          class EcksteinHechlerPropagator
        }
        package tle #CCCCC7 {
          class TLEPropagator
        }
      }

      package "semianalytical.dsst" #CBDBC8 {
        package forces #CCCCC7 {
          interface DSSTForceModel
        }
      }

    }

    package orbits #DDEBD8 {
      abstract class Orbit
    }

  }

  package org.hipparchus #ECEBD8 {
    interface LeastSquaresOptimizer
  }

  FixedPointConverter      ..|> OsculatingToMeanConverter
  LeastSquaresConverter    ..|> OsculatingToMeanConverter

  BrouwerLyddaneTheory  ..|> MeanTheory
  EcksteinHechlerTheory ..|> MeanTheory
  DSSTTheory            ..|> MeanTheory
  TLETheory             ..|> MeanTheory

  OsculatingToMeanConverter "1" o--> "1" MeanTheory : theory
  OsculatingToMeanConverter -right-> Orbit

  BrouwerLyddaneTheory  --> BrouwerLyddanePropagator
  EcksteinHechlerTheory --> EcksteinHechlerPropagator
  TLETheory             --> TLEPropagator
  DSSTTheory "1" *--> "*" DSSTForceModel

  LeastSquaresConverter o--> "1" LeastSquaresOptimizer

  ' Force propagation package below osc2mean
  MeanTheory -[hidden]down-> BrouwerLyddanePropagator


@enduml
